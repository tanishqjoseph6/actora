# SUPABASE_SERVICE_ROLE, SUPABASE_JWT_SECRET, SUPABASE_DB_URL

# OpenAI — one value only (do not paste other KEY= lines on the same row in Vercel)
OPENAI_API_KEY=

# Trial emails (optional — cron still expires trials without this)
RESEND_API_KEY=
TRIAL_EMAIL_FROM=Actora <onboarding@useactora.com>
CRON_SECRET=

# Billing — USD to INR conversion for Razorpay INR plans (default: 88)
USD_INR_EXCHANGE_RATE=88

# Razorpay plan IDs (create in Razorpay dashboard with INR amounts)
# Pro Monthly: $25 equivalent | Pro Yearly: $255 equivalent
# Team Monthly: $69 equivalent | Team Yearly: $704 equivalent
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_PRO_YEARLY_PLAN_ID=
RAZORPAY_TEAM_PLAN_ID=
RAZORPAY_TEAM_YEARLY_PLAN_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
