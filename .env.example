# App URL — required in Vercel production (canonical domain for links + OAuth hints)
NEXT_PUBLIC_APP_URL=https://useactora.com

# NextAuth + Google OAuth (sign-in / sign-up)
# Vercel production: NEXTAUTH_URL must be https://useactora.com (not localhost or preview URLs)
# Local dev: NEXTAUTH_URL=http://localhost:3000 and register that callback in Google Cloud Console
NEXTAUTH_URL=https://useactora.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Supabase — one project only (local + Vercel production must match)
# Dashboard: https://supabase.com/dashboard/project/<project-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Do NOT set legacy/duplicate names (remove from Vercel if present):
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_KEY, NEXT_PUBLIC_SUPABASE_KEY,
# SUPABASE_SERVICE_ROLE, SUPABASE_JWT_SECRET, SUPABASE_DB_URL

# OpenAI — one value only (do not paste other KEY= lines on the same row in Vercel)
OPENAI_API_KEY=

# Production email (Resend) — set in Supabase Edge Function secrets, NOT here:
#   supabase secrets set RESEND_API_KEY=re_... EMAIL_FROM="Actora <onboarding@useactora.com>"
# Optional relay guard (also set as Edge secret):
#   supabase secrets set SEND_EMAIL_SECRET=long-random-string
# Deploy: supabase functions deploy send-email

# Trial cron (optional — cron still expires trials without email)
CRON_SECRET=

# Billing — USD to INR conversion for Razorpay INR plans (default: 88)
USD_INR_EXCHANGE_RATE=90

# Razorpay — LIVE keys for production (rzp_live_…). Use rzp_test_ only in local test checkouts.
# Plan IDs must be from the same mode dashboard as the keys.
# Pro monthly must be production pricing (₹1,760 / $20) — never a ₹1 test plan.
# Team monthly: ₹6,072 / $69
# Set to "true" only to temporarily hide billing checkout (staging kill-switch)
# NEXT_PUBLIC_BILLING_PAUSED=true

RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_PRO_YEARLY_PLAN_ID=
RAZORPAY_TEAM_PLAN_ID=
RAZORPAY_TEAM_YEARLY_PLAN_ID=
